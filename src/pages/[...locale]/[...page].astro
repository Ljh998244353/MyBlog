---
import MainPageLayout from "@layouts/MainPageLayout.astro";
import Cover from "@components/Cover.astro";
import PostCard from "@components/PostCard.astro";
import FabMenu from "@components/control/FabMenu.astro";

import {
  getBlogEntrySort,
  isFeaturedPost,
  sortByPinnedThenPubDateDesc,
  type BlogEntryWithLocaleStatus,
} from "@utils/content-utils";
import { SITE, siteConfig } from "@/config";
import { i18n } from "astro:config/client";
import type { GetStaticPaths } from "astro";
import { blogCoverUrl, getRelativeLocaleUrl } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

import i18nit from "@i18n/translation";

const {
  featuredPosts = [],
  recentPosts = [],
  totalFeaturedPosts = 0,
  totalPosts = 0,
} = Astro.props;

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);
const featuredUrl = getRelativeLocaleUrl(currentLang, "/featured/");
const postsUrl = getRelativeLocaleUrl(currentLang, "/posts/");

export const getStaticPaths = (async () => {
  const paths = [];
  const locales = i18n?.locales ?? ["zh-cn"];
  const defaultLocale = i18n?.defaultLocale ?? "zh-cn";

  for (const locale of locales) {
    const localeCode = typeof locale === "string" ? locale : locale.path;
    const localeParam = localeCode === defaultLocale ? undefined : localeCode;

    const blogEntries = await getBlogEntrySort(localeCode);
    const allFeaturedPosts = blogEntries
      .filter(isFeaturedPost)
      .sort(sortByPinnedThenPubDateDesc);
    const recentNonFeaturedPosts = blogEntries.filter(
      entry => !isFeaturedPost(entry)
    );

    paths.push({
      params: { locale: localeParam, page: undefined },
      props: {
        featuredPosts: allFeaturedPosts.slice(0, SITE.postPerIndex),
        recentPosts: recentNonFeaturedPosts.slice(0, SITE.postPerIndex),
        totalFeaturedPosts: allFeaturedPosts.length,
        totalPosts: blogEntries.length,
      },
    });
  }

  return paths;
}) satisfies GetStaticPaths;

const pageTitle = `${siteConfig.title} - ${siteConfig.subTitle}`;
const showFeatured = featuredPosts.length > 0;
const showRecent = recentPosts.length > 0;
---

<MainPageLayout title={pageTitle} lang={currentLang}>
  <Cover title={t("cover.title.home")} subTitle={t("cover.subTitle.home")} />
  {
    showFeatured && (
      <section class="mx-auto w-full max-w-[var(--page-width)]">
        <h2 class="mb-4 text-2xl font-bold text-[var(--text-color)]">
          推荐阅读
        </h2>
        {featuredPosts.map((entry: BlogEntryWithLocaleStatus) => (
          <PostCard
            entry={entry}
            title={entry.data.title}
            description={entry.data.description}
            image={blogCoverUrl(entry.data.image, entry.id)}
            pubDate={entry.data.pubDate}
            url={entry.routePath ?? entry.id}
            fallback={entry.isFallback ?? false}
          />
        ))}
        {totalFeaturedPosts > 0 && (
          <div class="mt-4 flex justify-end">
            <a
              href={featuredUrl}
              class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--text-color-70)] transition-colors hover:text-[var(--link-color)]"
            >
              查看全部精选
              <Icon name="fa6-solid:angle-right" />
            </a>
          </div>
        )}
      </section>
    )
  }
  {
    showRecent && (
      <section class="mx-auto w-full max-w-[var(--page-width)]">
        <h2 class="mt-10 mb-4 text-2xl font-bold text-[var(--text-color)]">
          最近更新
        </h2>
        {recentPosts.map((entry: BlogEntryWithLocaleStatus) => (
          <PostCard
            entry={entry}
            title={entry.data.title}
            description={entry.data.description}
            image={blogCoverUrl(entry.data.image, entry.id)}
            pubDate={entry.data.pubDate}
            url={entry.routePath ?? entry.id}
            fallback={entry.isFallback ?? false}
          />
        ))}
      </section>
    )
  }
  {
    totalPosts > 0 && (
      <div class="mx-auto mt-4 mb-8 flex w-full max-w-[var(--page-width)] justify-end">
        <a
          href={postsUrl}
          class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--text-color-70)] transition-colors hover:text-[var(--link-color)]"
        >
          查看全部文章
          <Icon name="fa6-solid:angle-right" />
        </a>
      </div>
    )
  }
  <FabMenu showBackBottom={true} />
</MainPageLayout>
