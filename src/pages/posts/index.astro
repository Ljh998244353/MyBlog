---
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts } from '../../utils/posts';

const posts = await getPublishedPosts();
const featuredPost = posts[0] ?? null;
const archivePosts = featuredPost ? posts.slice(1) : [];
---

<BaseLayout title="文章" description="按时间倒序查看所有已发布文章。">
  <section class="container section archive-section">
    <div class="section-heading archive-heading">
      <div>
        <p class="eyebrow">Archive / 内容归档</p>
        <h1>文章归档</h1>
      </div>
      <p>{posts.length} 篇已发布文章</p>
    </div>

    {
      featuredPost ? (
        <>
          <div class="archive-featured">
            <PostCard post={featuredPost} variant="featured" />
          </div>

          {
            archivePosts.length > 0 && (
              <div class="post-grid archive-grid">
                {archivePosts.map((post) => (
                  <PostCard post={post} />
                ))}
              </div>
            )
          }
        </>
      ) : (
        <div class="empty-state">
          <p>还没有已发布文章。</p>
        </div>
      )
    }
  </section>
</BaseLayout>
