---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { withBase } from "@/utils/site";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = withBase("/");
const homeHeroImage = SITE.homeHeroImage
  ? withBase(`/${SITE.homeHeroImage}`)
  : undefined;
const homeHeroStyle = homeHeroImage
  ? `--home-hero-image: url("${homeHeroImage}")`
  : undefined;
const homeHeroHandle = "welcome!";
const homeHeroTail = "";
---

<Layout>
  <section
    id="home-hero"
    data-home-hero
    class="home-hero"
    style={homeHeroStyle}
    aria-labelledby="home-hero-title"
  >
    <div class="home-hero-inner">
      <h1 id="home-hero-title" class="home-hero-title" aria-label={SITE.title}>
        <span class="home-hero-handle">{homeHeroHandle}</span>
        {homeHeroTail && <span class="home-hero-tail">{homeHeroTail}</span>}
      </h1>
      <p class="home-hero-hint" aria-hidden="true">
        <span class="home-hero-hint-track">
          <span>向下进入主页</span>
          <IconArrowRight class="size-4 rotate-90" />
        </span>
      </p>
    </div>
  </section>

  <div data-home-shell class="home-shell">
    <Header />
    <main
      id="main-content"
      data-layout="index"
      data-home-path={homePath}
      class="app-layout"
    >
      {
        featuredPosts.length > 0 && (
          <section
            id="featured"
            class:list={[
              "pt-12 pb-6",
              { "border-b border-border": recentPosts.length > 0 },
            ]}
          >
            <h2 class="text-2xl font-semibold tracking-wide">精选文章</h2>
            <ul>
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
        )
      }

      {
        recentPosts.length > 0 && (
          <section id="recent-posts" class="pt-12 pb-6">
            <h2 class="text-2xl font-semibold tracking-wide">最新文章</h2>
            <ul>
              {recentPosts.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h3" {...data} />
              )}
            </ul>
          </section>
        )
      }

      <div class="my-8 text-center">
        <LinkButton href="/posts/">
          查看全部文章
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
  const homeWindow = window as Window &
    typeof globalThis & {
      __homePageEventsBound?: boolean;
    };

  const setupHomePage = () => {
    const mainContent = document.querySelector(
      "#main-content"
    ) as HTMLElement | null;
    const indexLayout = mainContent?.dataset?.layout;
    const homePath = mainContent?.dataset?.homePath;

    if (indexLayout && homePath) {
      sessionStorage.setItem("backUrl", homePath);
    }
  };

  const setupHeroScroll = () => {
    const hero = document.querySelector("[data-home-hero]") as HTMLElement | null;
    if (!hero) return;

    let isSnapping = false;
    let snapTimer: ReturnType<typeof setTimeout> | null = null;
    let rafId = 0;
    const SNAP_THRESHOLD = 0.3;
    const SNAP_COOLDOWN = 600;

    const updateScroll = () => {
      const progress = Math.min(window.scrollY / window.innerHeight, 1);
      hero.style.setProperty("--hero-scroll", String(progress));
    };

    const snapIfNeeded = () => {
      if (isSnapping) return;
      const progress = window.scrollY / window.innerHeight;
      if (progress <= 0 || progress >= 1) return;

      isSnapping = true;
      const target = progress > SNAP_THRESHOLD ? window.innerHeight : 0;
      window.scrollTo({ top: target, behavior: "smooth" });

      setTimeout(() => {
        isSnapping = false;
      }, SNAP_COOLDOWN);
    };

    const onScroll = () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(updateScroll);

      if (snapTimer) clearTimeout(snapTimer);
      snapTimer = setTimeout(snapIfNeeded, 120);
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    updateScroll();
  };

  if (!homeWindow.__homePageEventsBound) {
    document.addEventListener("astro:page-load", () => {
      setupHomePage();
      setupHeroScroll();
    });
    homeWindow.__homePageEventsBound = true;
  }

  setupHomePage();
  setupHeroScroll();
</script>
