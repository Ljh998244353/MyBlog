---
import BaseLayout from '../components/BaseLayout.astro';
import TagChip from '../components/TagChip.astro';
import { siteConfig } from '../config/site';
import { withBase } from '../utils/paths';
import {
createExcerpt,
estimateReadingTime,
formatDate,
getPostPath,
getPublishedPosts,
getTagCounts
} from '../utils/posts';

const posts = await getPublishedPosts();
const featuredPost = posts[0] ?? null;
const latestPosts = featuredPost ? posts.slice(1, 5) : posts.slice(0, 4);
const hasLatestRail = latestPosts.length > 0;
const topTags = getTagCounts(posts).slice(0, 6);
const featuredPostPath = featuredPost ? withBase(getPostPath(featuredPost)) : withBase('/posts/');
const featuredReadingTime = featuredPost
  ? estimateReadingTime(featuredPost.body ?? featuredPost.data.description)
  : null;
const featuredExcerpt = featuredPost
  ? createExcerpt(featuredPost.body ?? featuredPost.data.description, 72)
  : '';
const heroLineChars = Array.from(siteConfig.heroLine).filter((char) => char.trim().length > 0);
const recentFocus = topTags
  .slice(0, 2)
  .map((tag) => tag.tag)
  .join(' / ');
const heroActivity = [
  {
    label: '最近更新',
    value: featuredPost ? formatDate(featuredPost.data.pubDate) : '准备中'
  },
  {
    label: '近期主题',
    value: recentFocus || '持续整理中'
  },
  {
    label: '已发布',
    value: `${posts.length} 篇文章`
  }
] as const;
---

<BaseLayout image="/head.jpg">
  <section class="hero container">
    <div class="hero-copy-block reveal reveal-1">
      <div class="hero-copy-panel">
        <div class="hero-profile">
          <div class="hero-profile-avatar-shell">
            <img class="hero-profile-avatar" src={withBase('/head.jpg')} alt={`${siteConfig.author} 的头像`} />
          </div>
          <div class="hero-profile-copy">
            <span class="hero-profile-kicker">Personal Log / 个人博客</span>
            <h1>{siteConfig.title}</h1>
          </div>
        </div>

        <p class="hero-line" aria-label={siteConfig.heroLine}>
          {heroLineChars.map((char) => (
            <span>{char}</span>
          ))}
        </p>

        <div class="hero-actions reveal reveal-2">
          <a class="button" href={featuredPostPath}>
            {featuredPost ? '最新文章' : '浏览文章'}
          </a>
          <a class="button button-secondary" href={withBase('/posts/')}>文章归档</a>
          <a class="button button-secondary" href={withBase('/search/')}>搜索</a>
        </div>
      </div>
    </div>

    <aside class="hero-activity reveal reveal-2" aria-label="最近动态">
      <p class="hero-activity-heading">最近动态</p>
      <div class="hero-activity-list">
        {heroActivity.map((item) => (
          <div class="hero-activity-item">
            <span class="hero-activity-label">{item.label}</span>
            <strong class="hero-activity-value">{item.value}</strong>
          </div>
        ))}
      </div>

      <a class="hero-activity-featured" href={featuredPostPath}>
        <span>最近文章</span>
        <strong>{featuredPost ? featuredPost.data.title : '浏览文章归档'}</strong>
      </a>
    </aside>
  </section>

  {
    featuredPost && (
      <section class="container section latest-section reveal reveal-2">
        <div class="section-heading">
          <h2>最近更新</h2>
          <a href={withBase('/posts/')}>查看全部</a>
        </div>

        <div class="latest-layout">
          <article class="featured-story">
            <div class="featured-story-body">
              <p class="featured-story-kicker">
                最近更新 · {formatDate(featuredPost.data.pubDate)} · {featuredReadingTime} 分钟阅读
              </p>
              <h3 class="featured-story-title">
                <a href={featuredPostPath}>{featuredPost.data.title}</a>
              </h3>
              <p class="featured-story-description">{featuredExcerpt}</p>
            </div>
            <div class="featured-story-actions">
              <a class="button" href={featuredPostPath}>阅读文章</a>
            </div>
          </article>

          <div class="latest-rail" aria-label="更多最新文章">
            {
              hasLatestRail ? (
                latestPosts.map((post) => {
                  const postPath = withBase(getPostPath(post));
                  const readingTime = estimateReadingTime(post.body ?? post.data.description);

                  return (
                    <article class="latest-rail-item">
                      <a class="latest-rail-link" href={postPath}>
                        <div class="latest-rail-copy">
                          <div class="latest-rail-meta">
                            <span>{formatDate(post.data.pubDate)}</span>
                            <span>{readingTime} 分钟阅读</span>
                          </div>
                          <h3 class="latest-rail-title">{post.data.title}</h3>
                        </div>
                        <span class="latest-rail-arrow" aria-hidden="true">
                          →
                        </span>
                      </a>
                    </article>
                  );
                })
              ) : (
                <article class:list={['latest-rail-item', 'latest-rail-placeholder']}>
                  <div class="latest-rail-copy">
                    <div class="latest-rail-meta">
                      <span>即将更新</span>
                      <span>更多内容整理中</span>
                    </div>
                    <h3 class="latest-rail-title">后续文章会按时间继续排在这里</h3>
                  </div>
                  <a class="button button-secondary" href={withBase('/posts/')}>浏览归档</a>
                </article>
              )
            }
          </div>
        </div>
      </section>
    )
  }

  <section class="container section topic-section reveal reveal-3">
    <div class="section-heading">
      <h2>按主题浏览</h2>
      <a href={withBase('/tags/')}>浏览标签</a>
    </div>

    <div class="tag-row">
      {topTags.map((tag) => (
        <TagChip tag={`${tag.tag} · ${tag.count}`} link={false} />
      ))}
    </div>
  </section>
</BaseLayout>
