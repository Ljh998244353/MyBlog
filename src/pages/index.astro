---
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TagChip from '../components/TagChip.astro';
import { siteConfig } from '../config/site';
import { getPublishedPosts, getTagCounts } from '../utils/posts';
import { withBase } from '../utils/paths';

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const topTags = getTagCounts(posts).slice(0, 6);
---

<BaseLayout>
  <section class="hero container">
    <div>
      <p class="eyebrow">Static blog starter</p>
      <h1>{siteConfig.title}</h1>
      <p class="hero-copy">{siteConfig.description}</p>
    </div>

    <div class="hero-panel">
      <p>适合长期写作的内容结构已经准备好：</p>
      <ul class="feature-list">
        <li>MDX 文章与自定义组件</li>
        <li>标签聚合、RSS、Sitemap、站内搜索</li>
        <li>GitHub Pages 自动构建与部署</li>
      </ul>
      <div class="hero-actions">
        <a class="button" href={withBase('/posts/')}>开始阅读</a>
        <a class="button button-secondary" href={withBase('/search/')}>搜索内容</a>
      </div>
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>最新文章</h2>
      <a href={withBase('/posts/')}>查看全部</a>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

  <section class="container section">
    <div class="section-heading">
      <h2>常用标签</h2>
      <a href={withBase('/tags/')}>浏览标签</a>
    </div>

    <div class="tag-row">
      {topTags.map((tag) => (
        <TagChip tag={`${tag.tag} · ${tag.count}`} link={false} />
      ))}
    </div>
  </section>
</BaseLayout>
