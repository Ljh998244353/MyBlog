---
import BaseLayout from '../components/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import TagChip from '../components/TagChip.astro';
import { siteConfig } from '../config/site';
import {
  estimateReadingTime,
  formatDate,
  getPostPath,
  getPublishedPosts,
  getTagCounts
} from '../utils/posts';
import { withBase } from '../utils/paths';

const posts = await getPublishedPosts();
const featuredPost = posts[0] ?? null;
const latestPosts = featuredPost ? posts.slice(1, 4) : posts.slice(0, 3);
const topTags = getTagCounts(posts).slice(0, 6);
const featuredPostPath = featuredPost ? withBase(getPostPath(featuredPost)) : withBase('/posts/');
const featuredReadingTime = featuredPost
  ? estimateReadingTime(featuredPost.body ?? featuredPost.data.description)
  : null;
---

<BaseLayout image="/head.jpg">
  <section class="hero container">
    <div class="hero-copy-block">
      <p class="eyebrow">Personal Notes</p>
      <h1>{siteConfig.title}</h1>
      <p class="hero-copy hero-copy-strong">{siteConfig.description}</p>
      <div class="hero-actions">
        <a class="button" href={featuredPostPath}>
          {featuredPost ? '最新文章' : '浏览文章'}
        </a>
        <a class="button button-secondary" href={withBase('/posts/')}>文章归档</a>
        <a class="button button-secondary" href={withBase('/search/')}>搜索</a>
      </div>
    </div>
  </section>

  {
    featuredPost && (
      <section class="container section">
        <div class="section-heading">
          <h2>最新文章</h2>
          <a href={featuredPostPath}>进入文章</a>
        </div>

        <article class="featured-story">
          <p class="featured-story-kicker">
            最近更新 · {formatDate(featuredPost.data.pubDate)} · {featuredReadingTime} 分钟阅读
          </p>
          <h3 class="featured-story-title">
            <a href={featuredPostPath}>{featuredPost.data.title}</a>
          </h3>
          <p class="featured-story-description">{featuredPost.data.description}</p>
          <div class="tag-row">
            {featuredPost.data.tags.map((tag) => (
              <TagChip tag={tag} />
            ))}
          </div>
          <div class="featured-story-actions">
            <a class="button" href={featuredPostPath}>打开文章</a>
            <a class="button button-secondary" href={withBase('/posts/')}>查看全部</a>
          </div>
        </article>
      </section>
    )
  }

  {
    latestPosts.length > 0 && (
      <section class="container section">
        <div class="section-heading">
          <h2>最近更新</h2>
          <a href={withBase('/posts/')}>查看全部</a>
        </div>

        <div class="post-grid">
          {latestPosts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      </section>
    )
  }

  <section class="container section">
    <div class="section-heading">
      <h2>按主题浏览</h2>
      <a href={withBase('/tags/')}>浏览标签</a>
    </div>

    <div class="tag-row">
      {topTags.map((tag) => (
        <TagChip tag={`${tag.tag} · ${tag.count}`} link={false} />
      ))}
    </div>
  </section>
</BaseLayout>
