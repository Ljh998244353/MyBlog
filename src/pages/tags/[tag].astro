---
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPublishedPosts, getTagCounts } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = getTagCounts(posts);

  return tags.map((tagEntry) => ({
    params: { tag: tagEntry.slug },
    props: {
      tag: tagEntry.tag,
      posts: posts.filter((post) => post.data.tags.includes(tagEntry.tag))
    }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`查看所有带有 ${tag} 标签的文章。`}>
  <section class="container section">
    <div class="section-heading">
      <h1>{tag}</h1>
      <p>{posts.length} 篇文章</p>
    </div>

    <div class="post-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
