---
import type { MarkdownLayoutProps } from "astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import LinkButton from "@/components/LinkButton.astro";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

type Props = MarkdownLayoutProps<{ title: string }>;

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{frontmatter.title}</h1>
      <slot />
      <h2>联系我</h2>
      <div class="not-prose mt-6 flex flex-col gap-4 sm:flex-row sm:flex-wrap">
        <LinkButton
          href="mailto:liu_jh2023@qq.com"
          class="gap-3 rounded-none bg-transparent px-0 py-0 shadow-none no-underline transition duration-200 hover:-translate-y-0.5 hover:text-foreground"
          title="发送邮件"
        >
          <IconMail class="size-6 flex-none stroke-2 transition duration-200 group-hover:-translate-y-0.5 group-hover:rotate-6" />
          <span class="flex flex-col text-left">
            <span class="text-xs uppercase tracking-[0.18em] opacity-60">Email</span>
            <span class="text-sm sm:text-base">liu_jh2023@qq.com</span>
          </span>
        </LinkButton>
        <LinkButton
          href={SITE.profile}
          class="gap-3 rounded-none bg-transparent px-0 py-0 shadow-none no-underline transition duration-200 hover:-translate-y-0.5 hover:text-foreground"
          title="查看 GitHub"
        >
          <IconGitHub class="size-6 flex-none stroke-2 transition duration-200 group-hover:-translate-y-0.5 group-hover:rotate-6" />
          <span class="flex flex-col text-left">
            <span class="text-xs uppercase tracking-[0.18em] opacity-60">GitHub</span>
            <span class="text-sm sm:text-base">ljh998244353</span>
          </span>
        </LinkButton>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
