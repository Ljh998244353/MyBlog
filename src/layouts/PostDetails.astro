---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content, headings } = await render(post);
const tocHeadings = headings.filter(
  heading => heading.depth === 2 || heading.depth === 3
);
const hasToc = tocHeadings.length > 0;

let ogImageUrl: string | undefined;

const stripMarkdownForReading = (value: string) =>
  value
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/!\[[^\]]*\]\([^)]+\)/g, " ")
    .replace(/\[[^\]]+\]\([^)]+\)/g, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/[>#*_~|()-]/g, " ")
    .replace(/[\[\]`]/g, " ");

const rawBody =
  (post as CollectionEntry<"blog"> & { body?: string }).body ?? description;
const readingText = stripMarkdownForReading(rawBody);
const cjkCount = readingText.match(/[\u3400-\u9fff]/g)?.length ?? 0;
const latinWordCount =
  readingText.match(/[A-Za-z0-9]+(?:[-_'][A-Za-z0-9]+)*/g)?.length ?? 0;
const readableUnitCount = cjkCount + latinWordCount;
const readingMinutes = Math.max(1, Math.ceil(readableUnitCount / 400));
const readableUnitLabel =
  readableUnitCount >= 1000
    ? `${(readableUnitCount / 1000).toFixed(1)}k 字`
    : `${readableUnitCount} 字`;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex < allPosts.length - 1
    ? allPosts[currentPostIndex + 1]
    : null;
---

<Layout {...layoutProps}>
  <Header wide={hasToc} />
  <BackButton wide={hasToc} />
  <main
    id="main-content"
    class:list={[
      "mx-auto flex w-full flex-col px-4 pb-12",
      {
        "mt-8": !SITE.showBackButton,
        "max-w-post": hasToc,
        "max-w-post-content": !hasToc,
      },
    ]}
    data-pagefind-body
  >
    <section class="post-hero">
      <h1 transition:name={slugifyStr(title)} class="post-title">
        {title}
      </h1>

      <div
        data-pagefind-ignore
        class="post-meta mt-6 flex flex-wrap items-center justify-center gap-2 text-sm"
      >
        <Datetime {pubDatetime} {modDatetime} {timezone} />
        <span aria-hidden="true">|</span>
        <span>{readingMinutes} 分钟读完</span>
        <span aria-hidden="true">·</span>
        <span>{readableUnitLabel}</span>
        <span
          aria-hidden="true"
          class:list={[{ hidden: !SITE.editPost.enabled || hideEditPost }]}
        >
          |
        </span>
        <EditPost {hideEditPost} {post} />
      </div>
    </section>

    {
      hasToc && (
        <section
          class="post-toc post-toc-mobile mt-10 xl:hidden"
          data-pagefind-ignore
        >
          <h2 id="table-of-contents" class="post-toc-title">
            目录
          </h2>
          <details class="post-toc-details mt-4" open>
            <summary class="post-toc-summary">展开目录</summary>
            <div class="post-toc-body mt-4">
              <TableOfContents headings={tocHeadings} />
            </div>
          </details>
        </section>
      )
    }

    <div
      class:list={["post-layout mt-10", { "post-layout--with-toc": hasToc }]}
    >
      <article
        id="article"
        class="app-prose w-full prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
      >
        <Content />
      </article>

      {
        hasToc && (
          <aside
            class="post-toc post-toc-desktop hidden xl:block"
            data-pagefind-ignore
          >
            <div class="post-toc-desktop-sticky">
              <p class="post-toc-desktop-title">目录</p>
              <TableOfContents headings={tocHeadings} />
            </div>
          </aside>
        )
      }
    </div>

    <hr class="my-8 border-dashed" />

    {
      tags.length > 0 && (
        <ul class="my-8 flex flex-wrap gap-4" data-pagefind-ignore>
          {tags.map(tag => (
            <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
          ))}
        </ul>
      )
    }

    <BackToTopButton />

    <hr class="my-6 border-dashed" />

    <div
      data-pagefind-ignore
      class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between"
    >
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="post-neighbor-link flex max-w-full gap-2"
          >
            <IconChevronLeft class="mt-1 inline-block flex-none rtl:rotate-180" />
            <div>
              <span class="post-neighbor-label">上一篇</span>
              <div class="post-neighbor-title">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="post-neighbor-link flex max-w-full gap-2 text-end sm:ms-auto"
          >
            <div>
              <span class="post-neighbor-label">下一篇</span>
              <div class="post-neighbor-title">{nextPost.title}</div>
            </div>
            <IconChevronRight class="mt-1 inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    if (document.querySelector(".progress-container")) return;

    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-0.5 w-full bg-transparent";
    progressContainer.setAttribute("aria-hidden", "true");

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-0.5 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    const winScroll =
      document.body.scrollTop || document.documentElement.scrollTop;
    const height =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
    const myBar = document.getElementById("myBar");

    if (myBar) {
      myBar.style.width = scrolled + "%";
    }
  }

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll(
        "#article h2, #article h3, #article h4, #article h5, #article h6"
      )
    );
    for (const heading of headings) {
      heading.classList.add("group");
      if (heading.querySelector(".heading-link")) continue;

      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "复制";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      if (codeBlock.parentElement?.classList.contains("code-block-shell")) {
        continue;
      }

      codeBlock.querySelector(".copy-code")?.remove();

      const wrapper = document.createElement("div");
      wrapper.className = "code-block-shell";
      const fileLabel = codeBlock.querySelector(".code-block-file-label");
      const fileNameOffset = getComputedStyle(codeBlock)
        .getPropertyValue("--file-name-offset")
        .trim();

      if (fileNameOffset) {
        wrapper.style.setProperty("--file-name-offset", fileNameOffset);
      }

      const copyButton = document.createElement("button");
      copyButton.type = "button";
      copyButton.className = "copy-code";
      copyButton.setAttribute("aria-label", copyButtonLabel);
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);
      if (fileLabel) {
        wrapper.appendChild(fileLabel);
      }
      wrapper.appendChild(copyButton);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "已复制";
      button.setAttribute("aria-label", "已复制");

      setTimeout(() => {
        button.innerText = copyButtonLabel;
        button.setAttribute("aria-label", copyButtonLabel);
      }, 700);
    }
  }
  attachCopyButtons();

  function syncDesktopTocCursor(activeLink) {
    const desktopToc = document.querySelector(
      ".post-toc-desktop [data-toc-nav]"
    );
    const desktopTocScroller = document.querySelector(
      ".post-toc-desktop-sticky"
    );
    const cursor = desktopToc?.querySelector("[data-toc-cursor]");

    if (!desktopToc || !desktopTocScroller || !cursor || !activeLink) {
      if (cursor) {
        cursor.style.opacity = "0";
      }
      return;
    }

    const tocRect = desktopToc.getBoundingClientRect();
    const linkRect = activeLink.getBoundingClientRect();
    const cursorTop = Math.max(
      0,
      linkRect.top - tocRect.top + 0.15 * linkRect.height
    );
    const cursorHeight = Math.max(18, linkRect.height * 0.7);
    const activeId = activeLink.getAttribute("data-target-id");

    cursor.style.height = `${cursorHeight}px`;
    cursor.style.transform = `translateY(${cursorTop}px)`;
    cursor.style.opacity = "1";

    if (window.__postDetailActiveTocId !== activeId) {
      activeLink.scrollIntoView({ block: "nearest", inline: "nearest" });
      window.__postDetailActiveTocId = activeId;
    }
  }

  function syncActiveToc() {
    const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));

    if (tocLinks.length === 0) return;

    const headings = tocLinks
      .map(link => {
        const id = link.getAttribute("data-target-id");
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean);

    if (headings.length === 0) return;

    let activeId = headings[0].id;
    const offset = 180;

    for (const heading of headings) {
      if (heading.offsetTop <= window.scrollY + offset) {
        activeId = heading.id;
      }
    }

    for (const link of tocLinks) {
      const isActive = link.getAttribute("data-target-id") === activeId;
      link.setAttribute("aria-current", isActive ? "true" : "false");
    }

    const activeDesktopLink = tocLinks.find(
      link =>
        link.getAttribute("data-target-id") === activeId &&
        link.closest(".post-toc-desktop")
    );

    syncDesktopTocCursor(activeDesktopLink);
  }

  function syncReadingState() {
    updateScrollProgress();
    syncActiveToc();
  }

  if (!window.__postDetailScrollBound) {
    document.addEventListener("scroll", syncReadingState, { passive: true });
    window.addEventListener("resize", syncReadingState);
    window.__postDetailScrollBound = true;
  }

  syncReadingState();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
