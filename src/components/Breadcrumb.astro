---
import { stripBase, withBase } from "@/utils/site";

// Remove current url path and remove trailing slash if exists
const currentUrlPath = stripBase(Astro.url.pathname).replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);
const segmentLabelMap: Record<string, string> = {
  about: "关于",
  archives: "归档",
  posts: "文章",
  search: "搜索",
  tags: "标签",
};

const formatBreadcrumbLabel = (label: string) =>
  segmentLabelMap[label] ?? decodeURIComponent(label);

// if breadcrumb is 首页 > 文章 > 1 <etc>
// replace with 文章列表（第 N 页）
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `文章列表（第 ${breadcrumbList[1] || 1} 页）`);
}

// if breadcrumb is 首页 > 标签 > [tag] > [page] <etc>
// replace [tag] > [page] with [tag]（第 N 页）
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${decodeURIComponent(breadcrumbList[1])}${Number(breadcrumbList[2]) === 1 ? "" : `（第 ${breadcrumbList[2]} 页）`}`
  );
}
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={withBase("/")} class="opacity-80">首页</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {formatBreadcrumbLabel(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={withBase(`/${breadcrumb}/`)} class="capitalize opacity-70">
              {formatBreadcrumbLabel(breadcrumb)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
