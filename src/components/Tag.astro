---
import IconHash from "@/assets/icons/IconHash.svg";
import { withBase } from "@/utils/site";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  count?: number;
};

const { tag, tagName, size = "lg", count } = Astro.props;
---

<li>
  <a
    href={withBase(`/tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5",
      "border-b-2 border-dashed border-foreground",
      "transition-colors duration-200 hover:border-accent hover:text-accent",
      "focus-visible:border-none focus-visible:text-accent",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tagName}
    {
      typeof count === "number" && (
        <span class="ms-1 font-mono text-xs opacity-55">{count}</span>
      )
    }
  </a>
</li>
