---
import { i18n } from "astro:config/client";
import i18nit from "@i18n/translation";
import { getRelativeLocaleUrl } from "@utils/url-utils";

interface Props {
  page?: {
    currentPage: number;
    lastPage: number;
  };
  currentPage?: number;
  totalPages?: number;
  basePath?: string;
}

const {
  page,
  currentPage: currentPageProp,
  totalPages: totalPagesProp,
  basePath = "/",
} = Astro.props;

const currentPage = currentPageProp ?? page?.currentPage ?? 1;
const totalPages = totalPagesProp ?? page?.lastPage ?? 1;

const showPrevious = currentPage > 1;
const showNext = currentPage < totalPages;

// 逻辑：生成带省略号的页码数组
function getVisiblePages(current: number, total: number) {
  const delta = 1;
  const range = [];
  const rangeWithDots = [];
  let l;

  for (let i = 1; i <= total; i++) {
    if (
      i === 1 ||
      i === total ||
      (i >= current - delta && i <= current + delta)
    ) {
      range.push(i);
    }
  }

  for (let i of range) {
    if (l) {
      if (i - l === 2) {
        rangeWithDots.push(l + 1);
      } else if (i - l !== 1) {
        rangeWithDots.push("...");
      }
    }
    rangeWithDots.push(i);
    l = i;
  }
  return rangeWithDots;
}

const visiblePages = getVisiblePages(currentPage, totalPages);

const normalizedBasePath = basePath.endsWith("/") ? basePath : `${basePath}/`;

const getPageUrl = (p: number) => {
  return p === 1 ? normalizedBasePath : `${normalizedBasePath}page/${p}/`;
};

const currentLang = Astro.currentLocale || i18n!.defaultLocale;
const t = i18nit(currentLang);

// 样式类：整合了移动端和桌面端的差异
const btnBaseClass =
  "p-2 md:px-4 md:py-2 flex items-center border rounded-lg transition-all duration-200";
const btnActiveProps =
  "text-[var(--text-color)] hover:bg-[var(--button-hover-color)] border-[var(--button-border-color)] active:scale-90";
const btnDisabledProps =
  "text-[var(--text-color-30)] border-[var(--button-border-color)] opacity-40 cursor-not-allowed pointer-events-none";
---

{
  totalPages > 1 && (
    <nav
      data-aos="fade-up"
      class="mx-auto my-8 flex max-w-[var(--page-width)] flex-row items-center justify-between gap-1 text-sm"
    >
      <a
        href={
          showPrevious
            ? getRelativeLocaleUrl(currentLang, getPageUrl(currentPage - 1))
            : "#"
        }
        class={`${btnBaseClass} ${showPrevious ? btnActiveProps : btnDisabledProps}`}
        aria-label="Previous Page"
      >
        <svg
          class="h-5 w-5 md:mr-1.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"
          />
        </svg>
        <span class="hidden md:inline">{t("pageNavigation.previous")}</span>
      </a>

      <div class="no-scrollbar flex flex-nowrap items-center gap-1 overflow-x-auto md:gap-2">
        {visiblePages.map(p => {
          if (p === "...") {
            return (
              <span class="flex h-8 w-8 items-center justify-center text-[var(--text-color-70)] md:h-10 md:w-10">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <circle cx="5" cy="12" r="1.5" />
                  <circle cx="12" cy="12" r="1.5" />
                  <circle cx="19" cy="12" r="1.5" />
                </svg>
              </span>
            );
          }

          const isCurrent = p === currentPage;
          return (
            <a
              href={getRelativeLocaleUrl(currentLang, getPageUrl(p as number))}
              class={`flex h-8 w-8 items-center justify-center rounded-lg border transition-all duration-200 md:h-10 md:w-10 ${
                isCurrent
                  ? "pointer-events-none border-[var(--button-border-color)] font-bold text-[var(--text-color)]"
                  : "border-transparent text-[var(--text-color-70)] hover:border-[var(--button-border-color)] hover:text-[var(--text-color)] active:scale-90 active:bg-[var(--button-hover-color)]"
              }`}
            >
              {p}
            </a>
          );
        })}
      </div>

      <a
        href={
          showNext
            ? getRelativeLocaleUrl(currentLang, getPageUrl(currentPage + 1))
            : "#"
        }
        class={`${btnBaseClass} ${showNext ? btnActiveProps : btnDisabledProps}`}
        aria-label="Next Page"
      >
        <span class="hidden md:inline">{t("pageNavigation.next")}</span>
        <svg
          class="h-5 w-5 md:ml-1.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"
          />
        </svg>
      </a>
    </nav>
  )
}

<style>
  /* 隐藏滚动条，确保在极端窄屏下也能滑动页码 */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
