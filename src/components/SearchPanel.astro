---
interface Props {
  source: string;
}

const { source } = Astro.props;
---

<section class="search-panel">
  <label class="section-title" for="site-search">站内搜索</label>
  <input
    id="site-search"
    class="search-input"
    type="search"
    placeholder="搜索标题、标签、摘要或正文片段"
    autocomplete="off"
  />
  <p class="search-hint">索引仅包含已发布文章，不包含草稿内容。</p>
  <p id="search-status" class="search-status">输入关键词后显示结果。</p>
  <ul id="search-results" class="search-results"></ul>
</section>

<script is:inline define:vars={{ source }} type="module">
  /**
   * @typedef {{
   *   title: string;
   *   description: string;
   *   tags: string[];
   *   url: string;
   *   excerpt: string;
   *   content: string;
   *   pubDate: string;
   * }} SearchItem
   */

  /** @type {HTMLInputElement | null} */
  const input = document.querySelector('#site-search');
  /** @type {HTMLParagraphElement | null} */
  const status = document.querySelector('#search-status');
  /** @type {HTMLUListElement | null} */
  const results = document.querySelector('#search-results');

  /** @type {SearchItem[]} */
  let cache = [];

  /** @param {string} value */
  const normalize = (value) => value.toLowerCase().trim();

  /** @param {SearchItem} item @param {string} query */
  const rankItem = (item, query) => {
    let score = 0;

    if (normalize(item.title).includes(query)) score += 4;
    if (normalize(item.tags.join(' ')).includes(query)) score += 3;
    if (normalize(item.description).includes(query)) score += 2;
    if (normalize(item.content).includes(query)) score += 1;

    return score;
  };

  /** @param {string} message */
  const renderEmpty = (message) => {
    if (!results || !status) return;
    results.innerHTML = '';
    status.textContent = message;
  };

  /** @param {SearchItem[]} items @param {string} query */
  const renderResults = (items, query) => {
    if (!results || !status) return;

    if (!items.length) {
      renderEmpty(`没有找到和 “${query}” 相关的文章。`);
      return;
    }

    status.textContent = `找到 ${items.length} 篇相关文章。`;
    results.innerHTML = items
      .map(
        (item) => `
          <li class="search-result">
            <a class="search-result-title" href="${item.url}">${item.title}</a>
            <p>${item.excerpt}</p>
            <div class="tag-row">
              ${item.tags.map((tag) => `<span class="tag-chip">${tag}</span>`).join('')}
            </div>
          </li>
        `
      )
      .join('');
  };

  const loadIndex = async () => {
    if (cache.length) return cache;

    const response = await fetch(source);
    /** @type {SearchItem[]} */
    cache = await response.json();
    return cache;
  };

  input?.addEventListener('input', async (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLInputElement)) return;

    const query = normalize(target.value);

    if (!query) {
      renderEmpty('输入关键词后显示结果。');
      return;
    }

    const items = await loadIndex();
    const matched = items
      .map((item) => ({ ...item, score: rankItem(item, query) }))
      .filter((item) => item.score > 0)
      .sort((left, right) => right.score - left.score || right.pubDate.localeCompare(left.pubDate));

    renderResults(matched, query);
  });
</script>
