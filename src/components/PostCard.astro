---
import type { CollectionEntry } from 'astro:content';
import { estimateReadingTime, formatDate, getPostPath } from '../utils/posts';
import { withBase } from '../utils/paths';
import TagChip from './TagChip.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  variant?: 'default' | 'featured';
}

const {
  post,
  variant = 'default'
} = Astro.props;
const readingTime = estimateReadingTime(post.body ?? post.data.description);
const postPath = withBase(getPostPath(post));
---

<article class:list={['post-card', { 'is-featured': variant === 'featured' }]}>
  <div class="post-card-meta">
    <span class="meta-pill">{formatDate(post.data.pubDate)}</span>
    <span class="meta-pill">{readingTime} 分钟阅读</span>
  </div>

  <h3 class="post-card-title">
    <a href={postPath}>{post.data.title}</a>
  </h3>

  <p class="post-card-description">{post.data.description}</p>

  <div class="post-card-footer">
    <div class="tag-row">
      {post.data.tags.map((tag) => (
        <TagChip tag={tag} />
      ))}
    </div>

    <a class="post-card-more" href={postPath}>继续阅读</a>
  </div>
</article>
