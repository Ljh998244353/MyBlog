---
interface Props {
  title?: string;
}

const { title = "提示" } = Astro.props;
---

<aside
  class="my-6 border-l-4 border-[var(--link-color)] bg-[var(--button-hover-color)] px-4 py-3 text-[var(--text-color)]"
>
  <p class="mb-2 font-bold">{title}</p>
  <div class="leading-relaxed text-[var(--text-color-70)]">
    <slot />
  </div>
</aside>
