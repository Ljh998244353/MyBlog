---
interface Props {
  title?: string;
  tone?: 'note' | 'success' | 'warn';
}

const {
  title = '提示',
  tone = 'note'
} = Astro.props;
---

<aside class:list={['mdx-callout', `tone-${tone}`]}>
  <strong>{title}</strong>
  <div class="mdx-callout-body">
    <slot />
  </div>
</aside>

<style>
  .mdx-callout {
    border-radius: 1rem;
    border: 1px solid rgba(117, 93, 49, 0.18);
    padding: 1rem 1.1rem;
    margin: 1.5rem 0;
    background: rgba(255, 250, 242, 0.95);
  }

  .mdx-callout strong {
    display: block;
    margin-bottom: 0.45rem;
    letter-spacing: 0.02em;
  }

  .mdx-callout.tone-success {
    border-color: rgba(43, 122, 78, 0.25);
    background: rgba(236, 247, 240, 0.92);
  }

  .mdx-callout.tone-warn {
    border-color: rgba(176, 103, 37, 0.22);
    background: rgba(255, 243, 231, 0.92);
  }
</style>
