---
import { slugifySegment } from '../utils/posts';
import { withBase } from '../utils/paths';

interface Props {
  tag: string;
  active?: boolean;
  link?: boolean;
}

const {
  tag,
  active = false,
  link = true
} = Astro.props;

const className = ['tag-chip', active && 'is-active'].filter(Boolean).join(' ');
const href = withBase(`/tags/${slugifySegment(tag)}/`);
---

{
  link ? (
    <a class={className} href={href}>
      {tag}
    </a>
  ) : (
    <span class={className}>{tag}</span>
  )
}
