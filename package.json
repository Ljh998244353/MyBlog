{
  "name": "blog",
  "type": "module",
  "version": "5.5.1",
  "scripts": {
    "predev": "npm run prepare:content",
    "dev": "astro dev",
    "prestart": "npm run prepare:content",
    "start": "astro dev",
    "fill:dates": "node scripts/fill-post-dates.mjs",
    "sync:covers": "node scripts/sync-post-covers.mjs",
    "prepare:content": "npm run fill:dates && npm run sync:covers",
    "precheck": "npm run prepare:content",
    "check": "astro check",
    "prebuild": "npm run prepare:content",
    "build": "astro check && astro build && pagefind --site dist && cp -r dist/pagefind public/",
    "preview": "node scripts/preview.mjs",
    "publish": "node scripts/publish.mjs",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/svelte": "^7.2.4",
    "@iconify/svelte": "^5.2.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.18",
    "aos": "^2.3.4",
    "astro": "^5.16.6",
    "astro-icon": "^1.1.5",
    "dayjs": "^1.11.19",
    "katex": "^0.16.22",
    "lodash.kebabcase": "^4.1.1",
    "mdast-util-to-string": "^4.0.0",
    "photoswipe": "^5.4.4",
    "playwright": "^1.59.1",
    "reading-time": "^1.5.0",
    "rehype-mermaid": "^3.0.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.18.3",
    "sharp": "^0.34.5",
    "svelte": "^5.46.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@iconify-json/fluent": "^1.2.45",
    "@iconify-json/material-symbols": "^1.2.35",
    "@iconify-json/simple-icons": "^1.2.48",
    "@iconify-json/vscode-icons": "^1.2.29",
    "@pagefind/default-ui": "^1.4.0",
    "@shikijs/transformers": "^3.20.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "globals": "^16.5.0",
    "pagefind": "^1.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0"
  }
}
